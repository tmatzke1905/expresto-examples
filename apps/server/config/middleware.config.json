{
  "port": 3100,
  "host": "127.0.0.1",
  "contextRoot": "/api",
  "controllersPath": "./apps/server/dist/controllers",
  "log": {
    "level": "info",
    "application": "./logs/application.log",
    "access": "./logs/access.log"
  },
  "cors": {
    "enabled": true,
    "options": {
      "origin": true,
      "credentials": true
    }
  },
  "helmet": {
    "enabled": true,
    "options": {}
  },
  "rateLimit": {
    "enabled": false,
    "options": {}
  },
  "metrics": {
    "enabled": true,
    "endpoint": "/__metrics"
  },
  "telemetry": {
    "enabled": false,
    "serviceName": "expresto-examples"
  },
  "auth": {
    "jwt": {
      "enabled": true,
      "secret": "expresto_examples_runtime_secret_2026_live_auth",
      "algorithm": "HS256",
      "expiresIn": "1h"
    },
    "basic": {
      "enabled": true,
      "users": {
        "demo": "showcase-2026!"
      }
    }
  },
  "ops": {
    "enabled": false
  },
  "scheduler": {
    "enabled": true,
    "mode": "attached",
    "jobs": {
      "clockDemo": {
        "enabled": true,
        "cron": "*/10 * * * * *",
        "module": "./apps/server/src/jobs/clockDemo.job.ts"
      }
    }
  }
}
