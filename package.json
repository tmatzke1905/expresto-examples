{
  "name": "expresto-examples",
  "version": "0.1.0",
  "private": true,
  "description": "Example application workspace for expresto-server",
  "workspaces": [
    "apps/server",
    "apps/web"
  ],
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "build": "npm run build:web && npm run build:server && npm run build:preview",
    "build:preview": "npm run build:preview --workspace @expresto-examples/web",
    "build:server": "npm run build --workspace @expresto-examples/server",
    "build:web": "npm run build --workspace @expresto-examples/web",
    "check:structure": "node ./scripts/check-structure.mjs",
    "dev:server": "npm run dev --workspace @expresto-examples/server",
    "dev:web": "npm run dev --workspace @expresto-examples/web",
    "start": "npm run start --workspace @expresto-examples/server"
  }
}
